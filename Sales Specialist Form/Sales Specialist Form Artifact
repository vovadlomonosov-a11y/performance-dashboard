export default function SalesAssessment() {
    const [currentSection, setCurrentSection] = useState(0);
    const [candidateName, setCandidateName] = useState("");
    const [candidateEmail, setCandidateEmail] = useState("");
    const [responses, setResponses] = useState({});
    const [objectionIndex, setObjectionIndex] = useState(0);
    const [objectionTimer, setObjectionTimer] = useState(OBJECTION_TIME_LIMIT);
    const [objectionActive, setObjectionActive] = useState(false);
    const [objectionStarted, setObjectionStarted] = useState(false);
    const [selectedCRMs, setSelectedCRMs] = useState([]);
    const [startTime, setStartTime] = useState(null);
    const [sectionStartTimes, setSectionStartTimes] = useState({});
    const timerRef = useRef(null);
    const topRef = useRef(null);

    const objections = [
        `"That's way more than I expected."`,
        `"I need to talk to my wife about it."`,
        `"Can you just email me the quote? I'll look at it later."`,
        `"I found someone on Facebook who'll do it for half that price."`,
        `"I'm not sure I really need ceramic coating. My car's already 3 years old."`,
    ];

    useEffect(() => {
        if (objectionActive && objectionTimer > 0) {
            timerRef.current = setInterval(() => {
                setObjectionTimer((prev) => {
                    if (prev <= 1) {
                        clearInterval(timerRef.current);
                        setObjectionActive(false);
                        return 0;
                    }
                    return prev - 1;
                });
            }, 1000);
        }
        return () => clearInterval(timerRef.current);
    }, [objectionActive, objectionTimer]);

    useEffect(() => {
        if (currentSection === 0) {
            setStartTime(Date.now());
        }
    }, []);

    const scrollToTop = () => {
        if (topRef.current) {
            topRef.current.scrollIntoView({ behavior: "smooth", block: "start" });
        }
    };

    const updateResponse = (key, value) => {
        setResponses((prev) => ({ ...prev, [key]: value }));
    };

    const goNext = () => {
        if (currentSection < SECTIONS.length - 1) {
            const nextIdx = currentSection + 1;
            setCurrentSection(nextIdx);
            setSectionStartTimes((prev) => ({
                ...prev,
                [SECTIONS[nextIdx].id]: Date.now(),
            }));
            scrollToTop();
        }
    };

    const goBack = () => {
        if (currentSection > 0) {
            setCurrentSection(currentSection - 1);
            scrollToTop();
        }
    };

    const startObjection = () => {
        setObjectionStarted(true);
        setObjectionActive(true);
        setObjectionTimer(OBJECTION_TIME_LIMIT);
    };

    const submitObjection = () => {
        clearInterval(timerRef.current);
        setObjectionActive(false);
        const timeUsed = OBJECTION_TIME_LIMIT - objectionTimer;
        updateResponse(`objection_${objectionIndex}_time`, timeUsed);
        if (objectionIndex < objections.length - 1) {
            setObjectionIndex(objectionIndex + 1);
            setObjectionTimer(OBJECTION_TIME_LIMIT);
            setObjectionActive(true);
            setObjectionStarted(true);
        } else {
            setObjectionStarted(false);
        }
    };

    const toggleCRM = (crm) => {
        setSelectedCRMs((prev) => {
            const updated = prev.includes(crm)
                ? prev.filter((c) => c !== crm)
                : [...prev, crm];
            updateResponse("crm_tools", updated.join(", "));
            return updated;
        });
    };

    const getProgress = () => {
        return Math.round((currentSection / (SECTIONS.length - 1)) * 100);
    };

    const getTotalTime = () => {
        if (!startTime) return "N/A";
        const mins = Math.round((Date.now() - startTime) / 60000);
        return `${mins} min`;
    };

    const formatTime = (seconds) => {
        const m = Math.floor(seconds / 60);
        const s = seconds % 60;
        return `${m}:${s.toString().padStart(2, "0")}`;
    };

    const canProceed = useCallback(() => {
        const section = SECTIONS[currentSection];
        switch (section.id) {
            case "welcome":
                return candidateName.trim().length > 0 && candidateEmail.trim().length > 0;
            case "voice":
                return (
                    responses.voice_1?.trim()?.length > 0 &&
                    responses.voice_2?.trim()?.length > 0 &&
                    responses.voice_3?.trim()?.length > 0
                );
            case "written":
                return (
                    responses.written_text?.trim()?.length > 0 &&
                    responses.written_email?.trim()?.length > 0 &&
                    responses.written_casual?.trim()?.length > 0
                );
            case "sales":
                return (
                    responses.sales_cheap?.trim()?.length > 0 &&
                    responses.sales_shopper?.trim()?.length > 0 &&
                    responses.sales_ghost?.trim()?.length > 0
                );
            case "objections":
                return objections.every(
                    (_, i) => responses[`objection_${i}`]?.trim()?.length > 0
                );
            case "crm":
                return (
                    responses.crm_newlead?.trim()?.length > 0 &&
                    responses.crm_reporting?.trim()?.length > 0 &&
                    selectedCRMs.length > 0
                );
            case "timezone":
                return (
                    responses.tz_hours?.trim()?.length > 0 &&
                    responses.tz_hotlead?.trim()?.length > 0 &&
                    responses.tz_setup?.trim()?.length > 0
                );
            case "culture":
                return (
                    responses.culture_shop?.trim()?.length > 0 &&
                    responses.culture_feedback?.trim()?.length > 0 &&
                    responses.culture_why?.trim()?.length > 0
                );
            default:
                return true;
        }
    }, [currentSection, candidateName, candidateEmail, responses, selectedCRMs, objections]);

    const renderProgressBar = () => (
        <div style= { styles.progressContainer } >
        <div style={ styles.progressTrack }>
            <div
          style={ { ...styles.progressFill, width: `${getProgress()}%` } }
        />
        </div>
        < div style = { styles.progressLabels } >
            <span style={ styles.progressText }>
                Section { currentSection } of { SECTIONS.length - 2 }
    </span>
        < span style = { styles.progressText } > { getProgress() } % </span>
            </div>
            </div>
  );

    const renderSectionNav = () => (
        <div style= { styles.sectionNav } >
        {
            SECTIONS.filter((s) => s.id !== "welcome" && s.id !== "complete").map(
                (section, idx) => {
                    const realIdx = idx + 1;
                    const isActive = currentSection === realIdx;
                    const isComplete = currentSection > realIdx;
                    return (
                        <div
              key= { section.id }
                    style = {{
                ...styles.sectionDot,
                ...(isActive ? styles.sectionDotActive : {}),
                ...(isComplete ? styles.sectionDotComplete : {}),
              }
}
title = { section.title }
    >
    <span style={ styles.sectionDotIcon }>
        { isComplete? "✓": section.icon }
        </span>
        < span
style = {{
                  ...styles.sectionDotLabel,
                  ...(isActive ? { color: "#F5F0E8", fontWeight: 700 } : {}),
                }}
              >
    { section.title }
    </span>
    </div>
          );
        }
      )}
</div>
  );

